# Copy to .secret.local (gitignored — matches the *.local glob) to provide
# values for firebase-functions/params defineSecret() during emulator runs.
# In production these are set via `firebase functions:secrets:set BMS_API_KEY`
# and stored in Secret Manager — never in a repo file.
#
# BMS Africa (mnotify) SMS API key — https://developer.bms.africa
# Used by onRoomAssigned to send room-assignment texts.
BMS_API_KEY=
