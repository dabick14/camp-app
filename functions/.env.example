# Copy to .env and fill in.
#
# Firebase Web API key — same value as the client's VITE_FIREBASE_API_KEY
# (see .env.example at the repo root). Find it in Firebase Console →
# Project settings → General → Web API Key, or in the client's firebaseConfig.
# Used by provisionLeader to trigger Identity Toolkit's hosted
# password-reset email.
WEB_API_KEY=
