# Copy to .env and fill in.
#
# Firebase Web API key — same value as the client's VITE_FIREBASE_API_KEY
# (see .env.example at the repo root). Find it in Firebase Console →
# Project settings → General → Web API Key, or in the client's firebaseConfig.
# Used by provisionLeader to trigger Identity Toolkit's hosted
# password-reset email.
WEB_API_KEY=

# Local-dev-only SMS safety valve. When set, every room-assignment text
# sent while running under the Functions Emulator is redirected to this
# number instead of whatever phone is on the seeded/test participant —
# lets you verify the real BMS Africa integration without texting fake
# numbers. Format: any form normalizeGhanaPhone() accepts, e.g. 233XXXXXXXXX.
# Ignored entirely outside the emulator (see functions/src/sms/devOverride.ts)
# — this cannot cause a real send in production even if left set.
SMS_DEV_OVERRIDE_PHONE=
