rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    function isAdmin() {
      return request.auth != null
          && exists(/databases/$(db)/documents/admins/$(request.auth.uid));
    }

    // Cloud Firestore caches get()/exists() results per unique path for the
    // duration of a single rule evaluation, so repeated calls to leaderDoc()
    // below cost one read, not one per call site.
    function leaderDoc() {
      return get(/databases/$(db)/documents/leaders/$(request.auth.uid));
    }

    function isActiveLeader() {
      return request.auth != null
          && exists(/databases/$(db)/documents/leaders/$(request.auth.uid))
          && leaderDoc().data.active == true;
    }

    match /admins/{uid} {
      // Self existence-check: role detection (useUserRole) reads /admins/{uid}
      // for EVERY signed-in user — including leaders — to decide if they're an
      // admin. Without this, a leader's own read of their (non-existent) admin
      // doc is denied outright by isAdmin() and throws, instead of resolving to
      // exists() === false. Does not allow reading other users' admin docs.
      allow get: if request.auth != null && request.auth.uid == uid;
      allow list, get: if isAdmin();
      allow write: if false; // console-only — seeded manually
    }

    match /leaders/{uid} {
      // Leaders can read their own doc (to know their subGroupId, etc.)
      allow get: if request.auth != null && request.auth.uid == uid;
      // Admins can read all leaders (management UI)
      allow list, get: if isAdmin();
      // Created exclusively by the provisionLeader Cloud Function (Admin SDK
      // bypasses rules) — the one-active-leader-per-sub-group check only runs
      // there, so direct client creates are blocked even for admins.
      allow create: if false;
      allow delete: if isAdmin();
      // Reactivating a leader is the same one-active-leader-per-sub-group
      // hazard as creating one, and that check can't be expressed in rules
      // (no cross-document query support) — so admins must go through the
      // setLeaderActive Cloud Function for ANY update, same as create.
      // Leaders may still self-update only their own lastLoginAt directly.
      allow update: if request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLoginAt']);
    }

    match /camps/{campId} {
      allow read: if true; // camp metadata is not sensitive; registrationOpen gating is done client-side
      allow write: if isAdmin();

      match /subGroups/{subGroupId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /roomTypes/{roomTypeId} {
        allow read: if true;   // public — shown on registration form
        allow write: if isAdmin();
      }

      match /rooms/{roomId} {
        allow read, write: if isAdmin();
      }

      // Facility issue tickets — internal ops only, never coordinator/public.
      match /tickets/{ticketId} {
        allow read, write: if isAdmin();
      }

      // SMS send log — admin-read only. Written exclusively by the
      // onRoomAssigned Cloud Function (Admin SDK, bypasses rules); no direct
      // client write path exists, including for admins.
      match /smsLog/{logId} {
        allow read: if isAdmin();
        allow write: if false;
      }

      match /paymentBatches/{batchId} {
        // Admin full access.
        allow read, write: if isAdmin();

        // Leaders may list/get batches scoped to their own sub-group so the
        // leader registration page can check for an unreconciled batch BEFORE
        // rendering the form (UX pre-check only — the authoritative gate is
        // the server-side check in leaderRegisterParticipant, which uses the
        // Admin SDK and bypasses these rules). For `list`, the client query
        // MUST filter on subGroupId so Firestore can prove every result
        // satisfies this condition; an unscoped query is rejected outright.
        allow get, list: if isActiveLeader()
            && leaderDoc().data.campId == campId
            && resource.data.subGroupId == leaderDoc().data.subGroupId;
      }

      match /allocations/{allocationId} {
        // Admin-only — allocations are created/voided by admins; the gate
        // check in leaderRegisterParticipant uses the Admin SDK (bypasses rules).
        allow read, write: if isAdmin();
      }

      match /participants/{participantId} {
        allow read, delete: if isAdmin();
        // Admin may update any field EXCEPT: if the participant is already
        // confirmed (confirmedBatchId present), writes that touch feeOwed or
        // roomTypePreference* are blocked — changing the fee on a confirmed
        // participant silently corrupts the PAID→PARTIAL derivation.
        // Other fields (notes, tags, rooming, etc.) remain freely updatable
        // even on confirmed participants.
        allow update: if isAdmin() && (
          resource.data.get('confirmedBatchId', null) == null
          || !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['feeOwed', 'roomTypePreferenceId', 'roomTypePreferenceName'])
        );

        // Leaders may read only participants in their own sub-group, within
        // their own camp. For `list` to succeed, the client query must filter
        // on subGroupId (and implicitly campId via the collection path) so
        // Firestore can prove every possible result satisfies this condition
        // — an unscoped query is rejected outright, not silently filtered.
        allow get, list: if isActiveLeader()
            && leaderDoc().data.campId == campId
            && resource.data.subGroupId == leaderDoc().data.subGroupId;

        // Leaders may directly update ONLY the payment claim fields on
        // participants in their own sub-group. All other fields — including
        // amountPaid, roomId, checkInState, registrationState — are blocked.
        // The preferred write path is the setPaymentClaim Cloud Function
        // (Admin SDK, bypasses rules), but this rule adds defense-in-depth
        // so even a crafted direct write can't touch amountPaid or rooming.
        //
        // Confirmed participants (confirmedBatchId present) are fully locked —
        // the leader write-whitelist is blocked entirely. The authoritative
        // guard is the setPaymentClaim function (Part A); this rule covers
        // any direct client write that bypasses the function.
        allow update: if isActiveLeader()
            && leaderDoc().data.campId == campId
            && resource.data.subGroupId == leaderDoc().data.subGroupId
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['paymentClaimed', 'claimedBy', 'claimedAt', 'updatedAt', 'updatedBy'])
            && resource.data.get('confirmedBatchId', null) == null;

        // Participant creation is handled exclusively by Cloud Functions
        // (adminAddParticipant, leaderRegisterParticipant — both use the
        // Admin SDK, which bypasses rules). No direct client creates allowed.
        allow create: if false;
      }
    }
  }
}
