rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    function isAdmin() {
      return request.auth != null
          && exists(/databases/$(db)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      // Self existence-check: role detection (useUserRole) reads /admins/{uid}
      // for EVERY signed-in user — including leaders — to decide if they're an
      // admin. Without this, a leader's own read of their (non-existent) admin
      // doc is denied outright by isAdmin() and throws, instead of resolving to
      // exists() === false. Does not allow reading other users' admin docs.
      allow get: if request.auth != null && request.auth.uid == uid;
      allow list, get: if isAdmin();
      allow write: if false; // console-only — seeded manually
    }

    match /leaders/{uid} {
      // Leaders can read their own doc (to know their subGroupId, etc.)
      allow get: if request.auth != null && request.auth.uid == uid;
      // Admins can read all leaders (for management UI in Day C)
      allow list, get: if isAdmin();
      // Only admins write; leaders can update their own lastLoginAt only
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        (request.auth.uid == uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLoginAt']));
    }

    match /camps/{campId} {
      allow read: if true; // camp metadata is not sensitive; registrationOpen gating is done client-side
      allow write: if isAdmin();

      match /subGroups/{subGroupId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /roomTypes/{roomTypeId} {
        allow read: if true;   // public — shown on registration form
        allow write: if isAdmin();
      }

      match /rooms/{roomId} {
        allow read, write: if isAdmin();
      }

      match /participants/{participantId} {
        allow read, update, delete: if isAdmin();

        // Participant creation is handled exclusively by the registerParticipant
        // Cloud Function (admin SDK bypasses rules). No direct client writes allowed.
        allow create: if false;
      }
    }
  }
}
