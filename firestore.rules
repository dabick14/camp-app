rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    function isAdmin() {
      return request.auth != null
          && exists(/databases/$(db)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if false; // console-only — seeded manually
    }

    match /camps/{campId} {
      allow read: if true; // camp metadata is not sensitive; registrationOpen gating is done client-side
      allow write: if isAdmin();

      match /subGroups/{subGroupId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /roomTypes/{roomTypeId} {
        allow read: if true;   // public — shown on registration form
        allow write: if isAdmin();
      }

      match /rooms/{roomId} {
        allow read, write: if isAdmin();
      }

      match /participants/{participantId} {
        allow read, update, delete: if isAdmin();

        // Participant creation is handled exclusively by the registerParticipant
        // Cloud Function (admin SDK bypasses rules). No direct client writes allowed.
        allow create: if false;
      }

      match /paymentBatches/{batchId} {
        // Hubtel-created batches + manual quarantine assignment write here; the Hubtel
        // viewer reads them. Admin-only. (Any public read for registration-gating is the
        // base payments feature's call, not this integration's.)
        allow read, write: if isAdmin();
      }

      // Hubtel checkout sessions + audit trail. Webhook writes via the admin SDK
      // (bypasses rules); these cover the admin viewer + manual quarantine assign.
      match /hubtelTransactions/{txnId} {
        allow read, write: if isAdmin();
      }
    }

    // Top-level reference → campId pointer, written at checkout init by the admin and
    // read by the public callback Cloud Function (admin SDK). Admin-only for clients.
    match /hubtelReferences/{reference} {
      allow read, write: if isAdmin();
    }

    // Orphan Hubtel callbacks (no matching session) land here for admin review.
    match /hubtelQuarantine/{txnId} {
      allow read, write: if isAdmin();
    }
  }
}
