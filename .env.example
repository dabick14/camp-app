# Firebase project config — copy to .env.local and fill in
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# reCAPTCHA v3 site key — required in production (App Check)
VITE_RECAPTCHA_SITE_KEY=

# Optional: paste the debug token printed to the console on first dev run.
# Add the same token to Firebase console → App Check → Manage debug tokens.
VITE_APPCHECK_DEBUG_TOKEN=

#Hubtel Payment Gateway config
HUBTEL_API_KEY=
HUBTEL_ACCOUNT_ID=
HUBTEL_MERCHANT_ACCOUNT_NUMBER=